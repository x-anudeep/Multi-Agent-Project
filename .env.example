NODE_ENV=development
PORT=3000

# Optional. If omitted, the API uses an in-memory repository for local demos/tests.
DATABASE_URL=

# Fleetbase API settings. Local Fleetbase Docker exposes API through http://localhost:8000.
FLEETBASE_BASE_URL=http://localhost:8000
FLEETBASE_API_KEY=replace-me
FLEETBASE_ORDER_ENDPOINT=/v1/orders

# Optional. If set, LangChain triage can use OpenAI to extract shipment fields from raw text.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Twilio Voice Integration (for inbound call handling and recording)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WEBHOOK_URL=

# Outlook IMAP Email Parsing (for email intake and polling)
OUTLOOK_EMAIL=
OUTLOOK_PASSWORD=
IMAP_SERVER=imap-mail.outlook.com
IMAP_POLLING_INTERVAL_MS=300000

# PDF Quote Generation
PDF_LOGO_PATH=
PDF_OUTPUT_DIR=./quotes

# Outlook SMTP Email Delivery
OUTLOOK_SMTP_SERVER=smtp-mail.outlook.com
OUTLOOK_SMTP_USER=
OUTLOOK_SMTP_PASSWORD=
OUTLOOK_SMTP_PORT=587


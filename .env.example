NODE_ENV=development
PORT=3000

# Optional. Base URL the automation layer uses to call this same server's own
# API (POST /api/agents/triage, POST /api/orders) for phone/email intake.
# Defaults to http://localhost:PORT; override if running behind a proxy.
API_BASE_URL=

# Optional. If omitted, the API uses an in-memory repository for local demos/tests.
DATABASE_URL=

# Optional. Set to "true" to skip the phone/email dedup check (e.g. while
# demoing the same caller/order repeatedly). Leave unset in normal use.
DISABLE_DUPLICATE_CHECK=

# Fleetbase API settings. Local Fleetbase Docker exposes API through http://localhost:8000.
FLEETBASE_BASE_URL=http://localhost:8000
FLEETBASE_API_KEY=replace-me
FLEETBASE_ORDER_ENDPOINT=/v1/orders

# Optional. If set, LangChain triage can use OpenAI to extract shipment fields from raw text.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional. Used only if OPENAI_API_KEY isn't set. Groq's free-tier inference
# API (OpenAI-compatible) running an open Llama model. If neither this nor
# OpenAI is configured, extraction falls back to a plain regex heuristic.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Twilio Voice Integration (for inbound call handling and recording)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WEBHOOK_URL=

# Outlook IMAP Email Parsing (for email intake and polling)
OUTLOOK_EMAIL=
OUTLOOK_PASSWORD=
IMAP_SERVER=imap-mail.outlook.com
IMAP_POLLING_INTERVAL_MS=300000

# PDF Quote Generation
PDF_LOGO_PATH=
PDF_OUTPUT_DIR=./quotes

# Outlook SMTP Email Delivery
OUTLOOK_SMTP_SERVER=smtp-mail.outlook.com
OUTLOOK_SMTP_USER=
OUTLOOK_SMTP_PASSWORD=
OUTLOOK_SMTP_PORT=587


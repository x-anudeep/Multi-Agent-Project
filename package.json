{
  "name": "multi-agent-logistics-backend",
  "version": "1.0.0",
  "description": "Backend and AI agent services for a multi-agent logistics quotation system.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "node --test test/*.test.js",
    "fleetbase:start": "git submodule update --init external/fleetbase && node scripts/fleetbase-compose.js up -d",
    "fleetbase:setup": "node scripts/setup-fleetbase.js",
    "fleetbase:stop": "node scripts/fleetbase-compose.js down",
    "fleetbase:logs": "node scripts/fleetbase-compose.js logs -f --tail=150",
    "fleetbase:status": "node scripts/check-fleetbase.js"
  },
  "keywords": [
    "logistics",
    "multi-agent",
    "express",
    "fleetbase"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "pg": "^8.13.1",
    "uuid": "^11.0.5"
  }
}
